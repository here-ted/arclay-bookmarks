{
  "manifest_version": 3,
  "name": "Arc Sidebar Bookmarks & Tabs",
  "version": "1.0",
  "description": "An Arc-style sidebar for managing bookmarks and open tabs.",
  "permissions": [
    "sidePanel",
    "bookmarks",
    "tabs",
    "favicon",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "Open Sidebar"
  }
}
