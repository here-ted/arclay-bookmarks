{
  "manifest_version": 3,
  "name": "Arclike Bookmarks",
  "version": "1.0",
  "description": "A sidebar extension for managing bookmarks and open tabs.",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "permissions": [
    "sidePanel",
    "bookmarks",
    "tabs",
    "favicon",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "Open Arclike Bookmarks"
  }
}
